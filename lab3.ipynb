   "source": [
    "def count(line, word):\n",
    "    counter = 0\n",
    "    for i in line.split():\n",
    "        counter += i == word\n",
    "    return counter\n",
    "    \n",
    "print(count(\"hi hih\",\"hi\"))"
   ]
